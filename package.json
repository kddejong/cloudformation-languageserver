{
    "name": "@aws/cloudformation-languageserver",
    "displayName": "AWS CloudFormation",
    "version": "1.4.0",
    "id": "aws-cloudformation-languageserver",
    "description": "AWS CloudFormation Language Server implementation",
    "publisher": "aws",
    "author": "Amazon Web Services (AWS)",
    "license": "Apache-2.0",
    "main": "src/app/standalone.ts",
    "engines": {
        "node": ">=22.15.0 <22.17.0",
        "npm": ">=10.5.0"
    },
    "keywords": [
        "Amazon Web Services (AWS)",
        "Amazon",
        "CloudFormation",
        "Infrastructure as Code (IaC)",
        "Language Server"
    ],
    "scripts": {
        "clean": "rm -rf build && rm -rf bundle && rm -rf coverage && rm -rf node_modules && rm -rf out && rm -rf jscpd",
        "build": "rm -rf out && tsc -b",
        "watch": "rm -rf out && tsc -b -w",
        "test": "cross-env NODE_ENV=test vitest run",
        "test:integration": "cross-env NODE_ENV=test vitest run --config vitest.integration.config.ts",
        "test:unit": "cross-env NODE_ENV=test vitest run --config vitest.unit.config.ts",
        "test:leaks": "cross-env NODE_ENV=test vitest run --pool=forks --logHeapUsage",
        "lint": "eslint --cache --cache-location node_modules/.cache/eslint --max-warnings 0 .",
        "lint:fix": "npm run lint -- --fix",
        "build:go:dev": "GOPROXY=direct go build -C cfn-init/cmd -v -o ../../bundle/development/bin/cfn-init",
        "build:go:prod": "GOPROXY=direct go build -C cfn-init/cmd -v -o ../../bundle/production/bin/cfn-init",
        "test:go": "GOPROXY=direct go test -C cfn-init ./...",
        "bundle": "rm -rf out && webpack --env mode=development && npm run build:go:dev",
        "bundle:alpha": "rm -rf out && webpack --env mode=production --env env=alpha",
        "bundle:beta": "rm -rf out && webpack --env mode=production --env env=beta",
        "bundle:prod": "rm -rf out && webpack --env mode=production --env env=prod",
        "download-wheels": "tsx tools/download-wheels.ts",
        "build-cfn-guard": "tsx tools/build-cfn-guard.ts",
        "generate-release-manifest": "tsx tools/generate-release-manifest.ts",
        "benchmark": "cross-env NODE_ENV=test AWS_ENV=alpha node --max-old-space-size=16384 --expose-gc -r ts-node/register tools/benchmark.ts",
        "generate-metrics": "cross-env NODE_ENV=development AWS_ENV=alpha node --max-old-space-size=16384 -r ts-node/register tools/telemetry-generator.ts",
        "debug-tree": "node -r ts-node/register tools/debug_tree.ts",
        "generate:guard-rules": "node -r ts-node/register tools/generate-guard-rules.ts",
        "generate-attributions": "tsx tools/generate-attribution.ts",
        "check:duplicates": "jscpd",
        "prepare": "husky"
    },
    "dependencies": {
        "@aws-sdk/client-cloudcontrol": "3.982.0",
        "@aws-sdk/client-cloudformation": "3.982.0",
        "@aws-sdk/client-iam": "3.982.0",
        "@aws-sdk/client-s3": "3.982.0",
        "@aws-sdk/client-sts": "3.982.0",
        "@aws-sdk/credential-provider-node": "3.972.5",
        "@base2/pretty-print-object": "1.0.2",
        "@opentelemetry/api": "1.9.0",
        "@opentelemetry/auto-instrumentations-node": "0.62.1",
        "@opentelemetry/resources": "2.0.1",
        "@opentelemetry/sdk-logs": "0.203.0",
        "@opentelemetry/sdk-metrics": "2.0.1",
        "@opentelemetry/sdk-node": "0.203.0",
        "@opentelemetry/sdk-trace-base": "2.0.1",
        "@opentelemetry/sdk-trace-node": "2.0.1",
        "@tree-sitter-grammars/tree-sitter-yaml": "0.7.1",
        "archiver": "7.0.1",
        "async-mutex": "0.5.0",
        "axios": "1.13.4",
        "cfn-guard": "file:./vendor/cfn-guard",
        "deep-object-diff": "1.1.9",
        "fast-deep-equal": "3.1.3",
        "fuse.js": "7.1.0",
        "ini": "5.0.0",
        "jose": "4.15.9",
        "js-yaml": "4.1.1",
        "lmdb": "3.4.2",
        "luxon": "3.7.1",
        "partial-json": "0.1.7",
        "pino": "9.9.0",
        "pino-pretty": "13.1.1",
        "proper-lockfile": "4.1.2",
        "pyodide": "0.28.2",
        "tree-sitter": "0.22.4",
        "tree-sitter-json": "0.24.8",
        "ts-essentials": "10.1.1",
        "uuid": "13.0.0",
        "vscode-languageserver": "9.0.1",
        "vscode-languageserver-textdocument": "1.0.12",
        "vscode-uri": "3.1.0",
        "yaml": "2.8.1",
        "yauzl": "3.2.0",
        "zod": "4.0.15"
    },
    "devDependencies": {
        "@aws-sdk/types": "3.973.1",
        "@eslint/js": "9.39.2",
        "@types/archiver": "7.0.0",
        "@types/js-yaml": "4.0.9",
        "@types/luxon": "3.7.1",
        "@types/node": "25.2.0",
        "@types/proper-lockfile": "4.1.4",
        "@types/semver": "7.7.1",
        "@types/yargs": "17.0.35",
        "@types/yauzl": "2.10.3",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/eslint-plugin": "1.6.6",
        "aws-sdk-client-mock": "4.1.0",
        "copy-webpack-plugin": "13.0.1",
        "cross-env": "10.1.0",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-promise": "7.2.1",
        "eslint-plugin-security": "3.0.1",
        "eslint-plugin-unicorn": "61.0.0",
        "husky": "9.1.7",
        "jscpd": "4.0.8",
        "minimatch": "10.1.2",
        "node-loader": "2.1.0",
        "prettier": "3.8.1",
        "process": "0.11.10",
        "semver": "7.7.3",
        "ts-loader": "9.5.4",
        "ts-node": "10.9.2",
        "ts-sinon": "2.0.2",
        "tsx": "4.21.0",
        "typescript": "5.9.3",
        "typescript-eslint": "8.54.0",
        "vitest": "4.0.18",
        "webpack": "5.101.3",
        "webpack-bundle-analyzer": "5.2.0",
        "webpack-cli": "6.0.1",
        "webpack-node-externals": "3.0.0",
        "worker-loader": "3.0.8",
        "yargs": "18.0.0"
    },
    "overrides": {
        "tree-sitter": "0.22.4"
    },
    "externalDependencies": [
        "@opentelemetry/api",
        "@opentelemetry/auto-instrumentations-node",
        "@opentelemetry/instrumentation-pino",
        "@opentelemetry/resources",
        "@opentelemetry/sdk-logs",
        "@opentelemetry/sdk-metrics",
        "@opentelemetry/sdk-node",
        "@opentelemetry/sdk-trace-base",
        "@opentelemetry/sdk-trace-node",
        "@tree-sitter-grammars/tree-sitter-yaml",
        "lmdb",
        "pino",
        "pino-pretty",
        "pyodide",
        "tree-sitter",
        "tree-sitter-json",
        "vscode-languageserver-types"
    ],
    "nativePrebuilds": [
        "@lmdb/lmdb-darwin-arm64",
        "@lmdb/lmdb-darwin-x64",
        "@lmdb/lmdb-linux-arm",
        "@lmdb/lmdb-linux-arm64",
        "@lmdb/lmdb-linux-x64",
        "@lmdb/lmdb-win32-arm64",
        "@lmdb/lmdb-win32-x64",
        "@msgpackr-extract/msgpackr-extract-darwin-arm64",
        "@msgpackr-extract/msgpackr-extract-darwin-x64",
        "@msgpackr-extract/msgpackr-extract-linux-arm",
        "@msgpackr-extract/msgpackr-extract-linux-arm64",
        "@msgpackr-extract/msgpackr-extract-linux-x64",
        "@msgpackr-extract/msgpackr-extract-win32-x64"
    ],
    "unusedDependencies": [
        "cbor-x"
    ],
    "rebuildDependencies": [
        "@tree-sitter-grammars/tree-sitter-yaml",
        "tree-sitter",
        "tree-sitter-json"
    ]
}
